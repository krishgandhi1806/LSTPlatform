build/
out/

# TypeScript v1 declaration files (if used)
typings/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Environment variables (Secrets)
.env
.env.test
.env.production

# Test output
coverage/
.nyc_output

# IDE / Editor folders
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# OS metadata
.DS_Store
Thumbs.db